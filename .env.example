# Non-secret local configuration. In APP_ENV=local/test, the backend reads app
# auth/session config from LOCAL_APP_SECRET_FILE and reads Azure/Langfuse keys
# from these environment variables. In non-local environments, secrets are read
# from AWS Secrets Manager using the names below.
APP_ENV=local
AWS_REGION=eu-west-2
SECRETS_STAGE=dev

# Optional local AWS credentials for Docker Compose only.
# Leave these unset in ECS so the backend uses its task role.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

APP_SECRET_NAME=/dstrmaysam-healthcare-knowledge-agent/dev/app
AZURE_OPENAI_SECRET_NAME=/dstrmaysam-healthcare-knowledge-agent/dev/azure-openai
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2025-04-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-4.1-mini
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
LANGFUSE_SECRET_NAME=/dstrmaysam-healthcare-knowledge-agent/dev/langfuse
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=
GUARDIAN_API_KEY=
GUARDIAN_NEWS_REFRESH_SECONDS=300
GUARDIAN_NEWS_PAGE_SIZE=10

S3_BUCKET=dstrmaysam-healthcare-knowledge-agent-dev
S3_RAW_PREFIX=raw/
S3_MANIFEST_KEY=manifests/documents.json

OPENSEARCH_ENDPOINT=
OPENSEARCH_INDEX=dstrmaysam-healthcare-knowledge-agent
DYNAMODB_CHAT_TABLE=dstrmaysam-healthcare-knowledge-agent-dev
# Chat history backends:
# - dynamodb_postgres: try DynamoDB first, fall back to Postgres if DynamoDB fails
# - dynamodb: DynamoDB only
# - postgres: Postgres only
# - memory: process memory only, not durable
CHAT_HISTORY_BACKEND=dynamodb_postgres
DOCUMENT_MANIFEST_CACHE_TTL_SECONDS=300
LANGFUSE_PROMPT_CACHE_TTL_SECONDS=300
CHAT_FAST_RAG_ENABLED=true
CHAT_FAST_RAG_MIN_QUERY_TERMS=3
MAX_GRAPH_LLM_CALLS=2
RAG_TOP_K=10
RAG_NEIGHBOR_CHUNKS=1
INGESTION_CHUNK_SIZE=1500
INGESTION_CHUNK_OVERLAP=250
RAG_PARALLEL_SEARCH_ENABLED=true
CHAT_BACKGROUND_HISTORY_SAVE_ENABLED=true
LANGFUSE_BACKGROUND_TRACE_UPDATE_ENABLED=true
CHAT_WARMUP_ENABLED=true
CHAT_WARMUP_LLM_CALL_ENABLED=false
CHAT_WARMUP_RETRIEVAL_ENABLED=true
LOCAL_DATA_DIR=/app/data
CHROMA_PERSIST_DIR=/app/data/chroma
CHROMA_COLLECTION=dstrmaysam-healthcare-knowledge-agent

# Local development secret fallback. If this file is missing in APP_ENV=local/test,
# the backend creates it with a generated session secret and the local username/password below.
LOCAL_APP_SECRET_FILE=/app/data/local_app_secret.json

# Local testing overlay only. Set false to stop injecting an extra test admin into
# the loaded app secret. This does not disable LOCAL_APP_SECRET_FILE.
LOCAL_TEST_ADMIN_ENABLED=true
LOCAL_TEST_ADMIN_USERNAME=admin
LOCAL_TEST_ADMIN_PASSWORD=admin123

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=healthcare_agent
POSTGRES_USER=healthcare_agent
POSTGRES_PASSWORD=healthcare_agent_dev
POSTGRES_SSLMODE=disable
DETERMINISTIC_LOOKUP_ENABLED=true
DETERMINISTIC_LOOKUP_MULTIPART_FIRST_ENABLED=false

BACKEND_URL=http://backend:8000
