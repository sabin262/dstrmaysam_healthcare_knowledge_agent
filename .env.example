# Non-secret local configuration only. Secret values must live in AWS Secrets Manager.
APP_ENV=local
AWS_REGION=eu-west-2
SECRETS_STAGE=dev

APP_SECRET_NAME=/company-assistant/dev/app
AZURE_OPENAI_SECRET_NAME=/company-assistant/dev/azure-openai
LANGFUSE_SECRET_NAME=/company-assistant/dev/langfuse

S3_BUCKET=company-assistant-dev
S3_RAW_PREFIX=raw/
S3_MANIFEST_KEY=manifests/documents.json

OPENSEARCH_ENDPOINT=
OPENSEARCH_INDEX=company-knowledge
DYNAMODB_CHAT_TABLE=company_assistant_chat_history
CHAT_HISTORY_BACKEND=memory

# Local testing only. This is ignored unless APP_ENV is local or test.
LOCAL_TEST_ADMIN_ENABLED=true
LOCAL_TEST_ADMIN_USERNAME=admin
LOCAL_TEST_ADMIN_PASSWORD=admin123

BACKEND_URL=http://backend:8000
