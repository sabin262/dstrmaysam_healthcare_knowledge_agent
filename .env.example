# Non-secret local configuration only. Secret values must live in AWS Secrets Manager.
APP_ENV=local
AWS_REGION=eu-west-2
SECRETS_STAGE=dev

# Optional local AWS credentials for Docker Compose only.
# Leave these unset in ECS so the backend uses its task role.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

APP_SECRET_NAME=/dstrmaysam-healthcare-knowledge-agent/dev/app
AZURE_OPENAI_SECRET_NAME=/dstrmaysam-healthcare-knowledge-agent/dev/azure-openai
LANGFUSE_SECRET_NAME=/dstrmaysam-healthcare-knowledge-agent/dev/langfuse

S3_BUCKET=dstrmaysam-healthcare-knowledge-agent-dev
S3_RAW_PREFIX=raw/
S3_MANIFEST_KEY=manifests/documents.json

OPENSEARCH_ENDPOINT=
OPENSEARCH_INDEX=dstrmaysam-healthcare-knowledge-agent
DYNAMODB_CHAT_TABLE=dstrmaysam-healthcare-knowledge-agent-dev
CHAT_HISTORY_BACKEND=memory

# Local testing only. This is ignored unless APP_ENV is local or test.
LOCAL_TEST_ADMIN_ENABLED=true
LOCAL_TEST_ADMIN_USERNAME=admin
LOCAL_TEST_ADMIN_PASSWORD=admin123

BACKEND_URL=http://backend:8000
