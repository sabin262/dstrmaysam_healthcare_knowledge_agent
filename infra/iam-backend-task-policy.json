{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadRequiredSecrets",
      "Effect": "Allow",
      "Action": "secretsmanager:GetSecretValue",
      "Resource": [
        "arn:aws:secretsmanager:<region>:<account-id>:secret:/dstrmaysam-healthcare-knowledge-agent/dev/app-*",
        "arn:aws:secretsmanager:<region>:<account-id>:secret:/dstrmaysam-healthcare-knowledge-agent/dev/azure-openai-*",
        "arn:aws:secretsmanager:<region>:<account-id>:secret:/dstrmaysam-healthcare-knowledge-agent/dev/langfuse-*"
      ]
    },
    {
      "Sid": "WriteAppUserSecret",
      "Effect": "Allow",
      "Action": "secretsmanager:PutSecretValue",
      "Resource": "arn:aws:secretsmanager:<region>:<account-id>:secret:/dstrmaysam-healthcare-knowledge-agent/dev/app-*"
    },
    {
      "Sid": "ReadWriteKnowledgeBucket",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::dstrmaysam-healthcare-knowledge-agent-dev",
        "arn:aws:s3:::dstrmaysam-healthcare-knowledge-agent-dev/*"
      ]
    },
    {
      "Sid": "ReadWriteChatHistory",
      "Effect": "Allow",
      "Action": [
        "dynamodb:GetItem",
        "dynamodb:PutItem",
        "dynamodb:Query",
        "dynamodb:UpdateItem"
      ],
      "Resource": "arn:aws:dynamodb:<region>:<account-id>:table/dstrmaysam-healthcare-knowledge-agent-dev"
    },
    {
      "Sid": "OpenSearchServerlessAccess",
      "Effect": "Allow",
      "Action": [
        "aoss:APIAccessAll"
      ],
      "Resource": "arn:aws:aoss:<region>:<account-id>:collection/<collection-id>"
    }
  ]
}
